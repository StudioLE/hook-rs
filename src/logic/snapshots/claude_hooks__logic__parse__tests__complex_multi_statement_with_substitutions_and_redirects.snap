---
source: src/logic/parse.rs
expression: context
---
raw: "cargo doc --document-private-items -p globset 2>&1 | tail -5; grep -r \"impl.*Debug\" $(find target/doc -name \"struct.GlobMatcher.html\" 2>/dev/null) 2>/dev/null || echo \"checking source instead\"; grep \"derive\" $(find . -path \"*/globset/src/*.rs\" -not -path \"./target/*\" 2>/dev/null) 2>/dev/null || echo \"not in local source\""
children:
  - connector: ~
    children:
      - name: cargo
        args:
          - doc
          - "--document-private-items"
          - "-p"
          - globset
        has_heredoc: false
        contains_substitution: false
        nesting: []
      - name: tail
        args:
          - "-5"
        has_heredoc: false
        contains_substitution: false
        nesting: []
  - connector: Semi
    children:
      - name: grep
        args:
          - "-r"
          - "\"impl.*Debug\""
          - "$(find target/doc -name \"struct.GlobMatcher.html\" 2>/dev/null)"
        has_heredoc: false
        contains_substitution: true
        nesting: []
      - name: find
        args:
          - target/doc
          - "-name"
          - "\"struct.GlobMatcher.html\""
        has_heredoc: false
        contains_substitution: false
        nesting:
          - Substitution
  - connector: Or
    children:
      - name: echo
        args:
          - "\"checking source instead\""
        has_heredoc: false
        contains_substitution: false
        nesting: []
  - connector: Semi
    children:
      - name: grep
        args:
          - "\"derive\""
          - "$(find . -path \"*/globset/src/*.rs\" -not -path \"./target/*\" 2>/dev/null)"
        has_heredoc: false
        contains_substitution: true
        nesting: []
      - name: find
        args:
          - "."
          - "-path"
          - "\"*/globset/src/*.rs\""
          - "-not"
          - "-path"
          - "\"./target/*\""
        has_heredoc: false
        contains_substitution: false
        nesting:
          - Substitution
  - connector: Or
    children:
      - name: echo
        args:
          - "\"not in local source\""
        has_heredoc: false
        contains_substitution: false
        nesting: []
