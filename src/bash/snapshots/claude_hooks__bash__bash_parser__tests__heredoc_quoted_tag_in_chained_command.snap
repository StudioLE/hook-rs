---
source: src/bash/bash_parser.rs
expression: context
---
raw: "git add file.md && git commit -m \"$(cat <<'EOF'\nfeat(scope): Add feature\nEOF\n)\""
children:
  - connector: ~
    children:
      - name: git
        args:
          - add
          - file.md
        has_heredoc: false
        contains_substitution: false
        nesting: []
  - connector: And
    children:
      - name: git
        args:
          - commit
          - "-m"
          - "\"$(cat <<'EOF'\nfeat(scope): Add feature\nEOF\n)\""
        has_heredoc: false
        contains_substitution: true
        nesting: []
      - name: cat
        args: []
        has_heredoc: true
        contains_substitution: false
        nesting:
          - Substitution
